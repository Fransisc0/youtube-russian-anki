{
  "manifest_version": 3,
  "name": "YouTube Russian-to-Anki",
  "version": "0.1.0",
  "description": "Create Anki sentence cards from captioned YouTube videos.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "YouTube to Anki",
    "default_popup": "popup.html"
  }
}
